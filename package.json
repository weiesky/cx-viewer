{
  "name": "cx-viewer",
  "version": "1.0.10",
  "description": "Codex Logger visualization management tool",
  "license": "MIT",
  "main": "server.js",
  "type": "module",
  "exports": {
    ".": "./server.js",
    "./server.js": "./server.js",
    "./interceptor.js": "./interceptor.js"
  },
  "author": "tian1024527726",
  "bin": {
    "cxv": "cli.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "node build.js",
    "build:sourcemap": "CXV_SOURCEMAP=1 node build.js",
    "start": "node server.js",
    "test": "CXV_TEST=1 CXV_LOG_DIR=tmp node --test",
    "test:coverage": "CXV_TEST=1 CXV_LOG_DIR=tmp node --test --experimental-test-coverage --test-coverage-include='lib/*.js' --test-coverage-include='*.js'",
    "pack:dry-run": "node scripts/npm-pack-dry-run.mjs",
    "release:check": "npm test && npm run build && npm run pack:dry-run",
    "prepublishOnly": "npm run build",
    "electron:dev": "electron electron/main.js",
    "electron:build": "npm run build && electron-builder",
    "electron:sign": "npm run electron:build && ./scripts/mac-sign.sh",
    "electron:check-sign": "./scripts/check-sign-config.sh"
  },
  "keywords": [
    "codex"
  ],
  "contributors": [
    {
      "name": "tian1024527726",
      "email": "18868814352@163.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weiesky/cx-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/weiesky/cx-viewer/issues"
  },
  "homepage": "https://github.com/weiesky/cx-viewer#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "!dist/**/*.map",
    "src/",
    "public/",
    "index.html",
    "build.js",
    "vite.config.js",
    "jsconfig.json",
    "server.js",
    "cli.js",
    "proxy.js",
    "interceptor.js",
    "i18n.js",
    "findcx.js",
    "lib/",
    "server/lib/",
    "electron/",
    "scripts/",
    "plugins/",
    "pty-manager.js",
    "workspace-registry.js",
    "concepts/"
  ],
  "devDependencies": {
    "@ant-design/icons": "^5.6.1",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/view": "^6.41.0",
    "@electron/notarize": "^3.1.1",
    "@lezer/highlight": "^1.2.3",
    "@mdxeditor/editor": "^3.55.0",
    "@replit/codemirror-minimap": "^0.5.2",
    "@uiw/react-codemirror": "^4.25.8",
    "@vitejs/plugin-react": "^4.5.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "antd": "^5.29.2",
    "diff": "^8.0.3",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "marked": "^17.0.2",
    "mermaid": "^11.13.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-json-view-lite": "^2.1.0",
    "react-virtuoso": "^4.18.3",
    "terser": "^5.48.0",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@openai/codex-sdk": "0.142.5",
    "dompurify": "^3.3.3",
    "jszip": "^3.10.1",
    "node-pty": "^1.1.0",
    "undici": "^7.22.0",
    "ws": "^8.19.0"
  }
}
