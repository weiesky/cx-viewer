{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "jsx": "preserve",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "strictNullChecks": false
  },
  "include": [
    "src/**/*",
    "server/**/*",
    "test/**/*",
    "electron/**/*",
    "scripts/**/*",
    "cli.js",
    "findcx.js",
    "server.js",
    "interceptor.js",
    "vite.config.js"
  ],
  "exclude": ["node_modules", "build", "dist"]
}
